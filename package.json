{
  "name": "shopping-cart",
  "type": "commonjs",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "TS_NODE_PROJECT=tsconfig.jest.json jest tests/unit",
    "test:unit": "TS_NODE_PROJECT=tsconfig.jest.json jest tests/unit",
    "test:integration": "TS_NODE_PROJECT=tsconfig.jest.json jest tests/integration --runInBand",
    "test:api": "start-server-and-test dev http://localhost:4321 test:integration",
    "test:all": "npm run test:unit && npm run test:api"
  },
  "dependencies": {
    "astro": "^7.0.6",
    "dotenv": "^17.4.2",
    "mongoose": "^9.7.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.0",
    "jest": "^29.7.0",
    "start-server-and-test": "^3.0.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}

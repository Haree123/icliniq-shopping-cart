{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "rootDir": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "jest.config.ts"
  ]
}